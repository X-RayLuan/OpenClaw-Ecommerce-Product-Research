# Amazon POD 选品 skill — 数据源密钥（复制为 .env 并填入真实值；.env 已被 gitignore）

# MCP 端点：Amazon 商品/榜单/评论 + Google Trends/AI Overview + WIPO/PACER
# 形如 https://mcp.<vendor>/mcp?api_key=xxxxx
PANGOLIN_MCP_URL=

# Tavily：Reddit / 社媒 / web 讨论检索
TAVILY_API_KEY=

# kie.ai：gpt-image-2 出图
KIE_API_KEY=

# Exa：神经检索，补 1688/阿里国际站/独立站/中文工厂端竞品（Pangolin 覆盖不到的源）
EXA_API_KEY=

# EchoTik Open API：TikTok Shop 商品/小店/达人/视频销量数据（兴趣电商 Step 3）
# 在 echotik.live → API → API Keys 生成 username/password，HTTP Basic Auth
ECHOTIK_API_USERNAME=
ECHOTIK_API_PASSWORD=
